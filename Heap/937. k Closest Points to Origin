import heapq
class Solution:
    def kClosest(self, points: List[List[int]], k: int) -> List[List[int]]:
        ans=[]
        heapq.heapify(ans)
        def distance(point)->int:
            x,y=point
            return x*x +y*y
        ans=[ ]
        for point in points:
            heapq.heappush(ans, (-distance(point),point))
            if len(ans)>k:
                heapq.heappop(ans)
        return [point  for _,point in ans]
